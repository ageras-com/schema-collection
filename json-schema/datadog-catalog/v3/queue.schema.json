{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://raw.githubusercontent.com/ageras-com/schema-collection/v1/json-schema/datadog-catalog/v3/queue.schema.json",
  "title": "Datadog Queue Catalog Schema - Ageras",
  "description": "Ageras-specific narrowing of the Datadog v3 queue catalog schema. Restricts lifecycle, tier, and contact/link channel types to organisation-approved enum values while delegating all structural validation to the upstream schema. Note: queue entities normally inherit lifecycle/tier from their system via inheritFrom; these enums only apply when the fields are set explicitly.",
  "allOf": [
    {
      "$ref": "https://raw.githubusercontent.com/DataDog/schema/main/service-catalog/v3/queue.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "spec": {
          "type": "object",
          "properties": {
            "lifecycle": {
              "description": "The maturity state of the queue (not the deployment environment).",
              "enum": ["experimental", "production", "deprecated"]
            },
            "tier": {
              "description": "House criticality tier (1=highest).",
              "enum": ["1", "2", "3", "4"]
            }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "contacts": {
              "items": {
                "properties": {
                  "type": {
                    "description": "Contact channel type.",
                    "enum": ["email", "slack", "microsoft-teams", "pagerduty"]
                  }
                }
              }
            },
            "links": {
              "items": {
                "properties": {
                  "type": {
                    "description": "Link category.",
                    "enum": ["runbook", "doc", "repo", "dashboard", "other"]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
