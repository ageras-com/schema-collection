{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://raw.githubusercontent.com/ageras-com/schema-collection/v1/json-schema/datadog-catalog/v3/system.schema.json",
  "title": "Datadog System Catalog Schema - Shine",
  "description": "Shine-specific narrowing of the Datadog v3 system catalog schema. Restricts lifecycle, tier, and contact/link channel types to organisation-approved enum values while delegating all structural validation to the upstream schema.",
  "allOf": [
    {
      "$ref": "https://raw.githubusercontent.com/DataDog/schema/main/service-catalog/v3/system.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "spec": {
          "$ref": "https://raw.githubusercontent.com/ageras-com/schema-collection/v1/json-schema/datadog-catalog/v3/partials/spec-defaults.schema.json"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "contacts": {
              "items": {
                "properties": {
                  "type": {
                    "description": "Contact channel type.",
                    "enum": [
                      "email",
                      "slack"
                    ]
                  }
                }
              }
            },
            "links": {
              "items": {
                "properties": {
                  "type": {
                    "description": "Link category.",
                    "enum": [
                      "runbook",
                      "doc",
                      "adr",
                      "repo",
                      "dashboard",
                      "other"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
